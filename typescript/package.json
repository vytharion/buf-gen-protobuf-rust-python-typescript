{
  "name": "@vytharion/monorepo-pb",
  "version": "0.1.0",
  "description": "Protobuf TypeScript bindings for the monorepo.v1 schemas, regenerated by `buf generate`.",
  "license": "MIT",
  "author": "vytharion",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./gen/monorepo/v1": {
      "types": "./src/gen/monorepo/v1/index.ts",
      "import": "./src/gen/monorepo/v1/index.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "engines": {
    "node": ">=18",
    "bun": ">=1.1"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "bun test"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^1.10.0"
  },
  "devDependencies": {
    "@bufbuild/protoc-gen-es": "^1.10.0",
    "@types/bun": "^1.1.0",
    "typescript": "^5.5.0"
  },
  "keywords": [
    "protobuf",
    "buf",
    "monorepo",
    "grpc"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vytharion/buf-gen-protobuf-rust-python-typescript.git"
  }
}
